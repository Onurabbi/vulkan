build extern/SDL/CMakeFiles/install/local.util: CUSTOM_COMMAND extern/SDL/all
  COMMAND = cd /home/onurabbi/projects/workspace/vulkan/build/extern/SDL && /usr/bin/cmake -DCMAKE_INSTALL_LOCAL_ONLY=1 -P cmake_install.cmake

build extern/SDL/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/onurabbi/projects/workspace/vulkan/build/extern/SDL && /usr/bin/cmake --regenerate-during-build -S/home/onurabbi/projects/workspace/vulkan -B/home/onurabbi/projects/workspace/vulkan/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build extern/SDL/rebuild_cache: phony extern/SDL/CMakeFiles/rebuild_cache.util


#############################################
# Utility command for list_install_components

build extern/SDL/list_install_components: phony


#############################################
# Utility command for install

build extern/SDL/CMakeFiles/install.util: CUSTOM_COMMAND extern/SDL/all
  COMMAND = cd /home/onurabbi/projects/workspace/vulkan/build/extern/SDL && /usr/bin/cmake -P cmake_install.cmake
  DESC = Install the project...
  pool = console
  restat = 1

build extern/SDL/install: phony extern/SDL/CMakeFiles/install.util


#############################################
